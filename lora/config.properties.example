# Copy this file to ./config.properties for local runs, or mount it as /etc/lora/config.properties.

HF_TOKEN=
HF_HOME=/shared/hf_home
MODEL_ID=meta-llama/Llama-3.2-1B
MODEL_NAME=llm-finetune

RAY_ADDRESS=ray://192.168.0.182:10001
RAY_STORAGE_PATH=/shared/ray-checkpoints
RAY_NUM_WORKERS=1
USE_GPU=false

TRAIN_EPOCHS=3
TRAIN_BATCH=1
MAX_SEQ_LEN=256
LEARNING_RATE=2e-4
LORA_R=8
LORA_ALPHA=16

MLFLOW_TRACKING_URI=http://mlflow.cnapcloud.com
MLFLOW_MODEL_NAME=llm-finetune
MLFLOW_EXPERIMENT=llm-finetune-pipeline

MINIO_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_INSECURE=false
MINIO_BUCKET=lora-data
MINIO_RAW_OBJECT_KEY=raw/analysis_input.json

VALIDATION_MAX_NULL_RATIO=0.05
VALIDATION_MAX_DUP_RATIO=0.10
VALIDATION_MIN_SAMPLES=50
VALIDATION_MIN_AVG_TOKENS=10

EVAL_SAMPLE_COUNT=5
EVAL_MIN_IMPROVEMENT_RATIO=0.01

SMOKE_MAX_LATENCY_SEC=30.0
SMOKE_MAX_NEW_TOKENS=50

ARTIFACT_DIR=./artifacts